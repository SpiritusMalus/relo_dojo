# relo_dojo PROD .env template (deploy target: family-pie VPS, relo.family-pie.ru).
# Copy to /opt/relo_dojo/backend/.env on the box, fill the GENERATE/SET markers, chmod 600.
# NEVER commit the filled file — .env is gitignored.

# Hardened runtime: Swagger/OpenAPI off, CHECK_SECRET required, HSTS emitted (see app.core.config).
ENV=prod

# --- Required secrets (no defaults — app fails fast at startup if missing) ---
# Generate on the box:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=GENERATE_48B_URLSAFE
# Generate on the box:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in prod (ENV=prod): an ephemeral key would break /check across restarts/workers.
CHECK_SECRET=GENERATE_FERNET_KEY
# Postgres on this VPS (localhost). Create db/user per DEPLOY.md; pick a strong password.
DATABASE_URL=postgresql+asyncpg://relo:SET_DB_PASSWORD@127.0.0.1:5432/relo_dojo

# --- LLM provider = OpenRouter (one sk-or key fronts BOTH text and read-aloud voice) ---
# PASTE the OpenRouter key below, then restart → LLM live. The account MUST have purchased credits
# (https://openrouter.ai/settings/credits) — gemini-3.1-flash-lite is paid, so a zero-credit key
# returns HTTP 402 "Insufficient credits". Confirm live with: python scripts/verify_llm.py
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=SET_OPENROUTER_KEY        # sk-or-v1-...  (https://openrouter.ai/keys)
# gemini-3.1-flash-lite is on OpenRouter AND accepts audio input, so one slug does text + read-aloud.
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_TRANSCRIBE_MODEL=google/gemini-3.1-flash-lite
# Reasoning cap (insurance): flash-lite measures tok_think=0 on our calls either way, but a future
# model slug that thinks by default would silently burn 6x-priced reasoning tokens — keep "none".
OPENROUTER_REASONING_EFFORT=none
# Upstream routing: flash-lite's providers span 1.7s..9s TTFT on our cards (measured live);
# sort=latency trims the slow tail. Which upstream answered is logged per call (provider=… in
# journald). Verify after changes: python scripts/verify_llm.py --bench 5
OPENROUTER_PROVIDER_SORT=latency
# Other providers (anthropic, gemini-direct) are unused on OpenRouter and have config.py defaults —
# add their keys back only if you change LLM_PROVIDER. gemini-direct was only for the dropped Live dialog.

# --- Public URL (verification links, billing return) ---
APP_BASE_URL=https://relo.family-pie.ru

# CORS: the mobile app is not a browser, so this can stay empty. Add web origins (comma-separated)
# only if a browser page calls this API directly (e.g. a future web checkout).
ALLOWED_ORIGINS=

# Behind Caddy (a proxy we control) → trust the first X-Forwarded-For hop for the real client IP,
# so the rate-limiter keys per client, not per proxy.
TRUST_FORWARDED_FOR=true

# --- Email (account activation) — reg.ru hosting mailbox relo@family-pie.ru. EMAIL_FROM MUST equal
#     the authenticated mailbox or reg.ru rejects it. If auth fails, try SMTP_HOST=sm33.hosting.reg.ru. ---
EMAIL_FROM=relo@family-pie.ru
# Quoted: the value has a space, so `set -a; . .env` (bash-source) doesn't choke on it.
EMAIL_FROM_NAME="Relo Dojo"
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465
SMTP_USER=relo@family-pie.ru
SMTP_PASSWORD=SET_MAILBOX_PASSWORD
SMTP_SSL=true                                # true => implicit TLS on port 465

# --- Billing (premium) — OFF until the owner enables the rail (separate task). ---
BILLING_ENABLED=false
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# BILLING_RETURN_URL=https://relo.family-pie.ru/checkout/done

# --- Voice (pronunciation, read-aloud) — ON. /voice/transcribe records a phrase → verbatim text via
#     OpenRouter (OPENROUTER_TRANSCRIBE_MODEL). Realtime Live dialog is NOT available on OpenRouter.
#     Confirm live with: python scripts/verify_voice.py ---
VOICE_ENABLED=true
VOICE_MAX_AUDIO_BYTES=2000000
VOICE_MAX_AUDIO_SECONDS=20
VOICE_RATE_LIMIT=20
VOICE_RATE_WINDOW_S=60

# Schema auto-applies on startup (single instance). Keep true here.
AUTO_MIGRATE=true
