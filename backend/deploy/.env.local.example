# relo_dojo LOCAL .env template — for exercising the premium pay-rail on a laptop + Android emulator.
# Copy to backend/.env and fill the SET markers. .env is gitignored — never commit the filled file.
# This is for LOCAL TEST ONLY (YooKassa TEST shop, test cards, no real money). Do NOT promote to prod;
# prod uses backend/deploy/.env.prod.example with separate LIVE keys. Full loop: marketing/checkout/RUNBOOK-local-test.md.

# Dev runtime (Swagger on, ephemeral CHECK_SECRET allowed). Leave as dev for local work.
# ENV=dev

# --- App boot: minimal required ---
# Local Postgres (create db/user once, then point here). Or reuse your existing dev DB.
DATABASE_URL=postgresql+asyncpg://relo:SET_DB_PASSWORD@127.0.0.1:5432/relo_dojo
# Any throwaway value works locally.
JWT_SECRET=local-dev-secret-change-me

# --- LLM: keep the zero-key dev default so the app boots with no provider key. ---
# Billing does NOT need the LLM; leave ollama (or set gemini + a paid key if you also want LLM endpoints).
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# --- Billing (premium) — ON for the local rail test. ---
# Flip the rail on so /billing/* stops 404ing (router gates on this, config.py:185).
BILLING_ENABLED=true
# YooKassa TEST shop creds (Личный кабинет → тестовый магазин). TEST mode = test cards, no real money.
# CC cannot write live keys here — the owner pastes the TEST shopId + secret at runtime.
YOOKASSA_SHOP_ID=SET_TEST_SHOP_ID
YOOKASSA_SECRET_KEY=SET_TEST_SECRET_KEY
# Real YooKassa API host — outbound TLS from the laptop reaches it even in test mode (the re-fetch
# trust model means we verify payments against this, so it must be the real API, not a mock).
YOOKASSA_API_URL=https://api.yookassa.ru/v3
# Where YooKassa sends the browser back AFTER checkout. 10.0.2.2 = the host machine as seen from the
# Android emulator; :8080 = the locally served marketing/checkout/. Payment is confirmed by the
# webhook, not by landing here.
BILLING_RETURN_URL=http://10.0.2.2:8080/done.html

# Schema auto-applies on startup. Keep true locally.
AUTO_MIGRATE=true
