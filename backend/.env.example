# Backend environment template. Copy to .env and fill values (never commit .env).

# Runtime environment: dev (default) | prod. ENV=prod hardens the app: Swagger/OpenAPI are turned
# off (no /docs, /redoc, /openapi.json), CHECK_SECRET becomes REQUIRED (no silent ephemeral key),
# and the HSTS header is emitted. Leave unset/dev for local work.
# ENV=dev

# LLM provider: ollama (local dev, default) | anthropic | openai | gemini.
# Prod = API provider (decided 2026-06-11). Recommended prod = gemini once eval-passed (~71%
# cheaper than Haiku on this workload). Re-run evals (python -m evals.run_eval --provider ...) before
# flipping in prod; in dev feel free to experiment — answers may differ from Ollama.
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Gemini (recommended prod provider). Use a PAID key — the free tier is geo-blocked in the EEA.
# GEMINI_MODEL = the stable Flash-Lite id (the -preview alias is discontinued 2026-07-09).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
LLM_MAX_TOKENS=1024

# Ollama (local dev path) — the LLM runs on this host, app talks to backend only.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Generation temperature (tweak without touching code).
# Exercises: higher = more variety. Checking: lower = more consistent verdicts.
EXERCISE_TEMPERATURE=0.7
CHECK_TEMPERATURE=0.2

# Phase 4+ — auth / db
# JWT_SECRET=
# DATABASE_URL=

# Economy (monetization). Sensible defaults in code; override here if tuning.
# COIN_REWARD_CORRECT=2
# FREE_DAILY_LIMIT=20
# PRICE_OMAMORI=150
# PRICE_OMAMORI_PROMO=75
# PRICE_EXTRA_PACK=50
# EXTRA_PACK_SIZE=10
# REPAIR_BASE=80
# REPAIR_PER_DAY=2
# REPAIR_MAX=300
# SCROLLS_PER_DAY=3
# Auto-run alembic migrations on backend startup (default true).
# AUTO_MIGRATE=true
# Dev-only: POST /dev/premium toggles your Black Belt flag. NEVER true in prod.
# DEV_PREMIUM_TOGGLE=false
# Expose GET /events/retention (dev/admin readout; 404 when false).
# ANALYTICS_ADMIN=false
# Events table TTL in days — rows older than this are purged on startup. 0 = keep forever.
# EVENTS_TTL_DAYS=0

# Rate limiting (abuse / cost guard; in-process, single-instance). A per-bucket limit of 0 disables
# that bucket. Auth = brute-force guard (per IP); LLM = cost guard on model-backed endpoints.
# RATE_LIMIT_ENABLED=true
# AUTH_RATE_LIMIT=10
# AUTH_RATE_WINDOW_S=60
# LLM_RATE_LIMIT=40
# LLM_RATE_WINDOW_S=60
# Trust X-Forwarded-For's first hop for the client IP — enable ONLY behind a proxy you control
# (nginx/Caddy on the VPS); otherwise the header is client-spoofable. Off by default.
# TRUST_FORWARDED_FOR=false

# Email account activation. APP_BASE_URL is the PUBLIC backend URL the activation link points at
# (e.g. https://api.relodojo.app). Leave SMTP_HOST empty in dev → the link is logged, not sent.
# APP_BASE_URL=
# VERIFY_TOKEN_EXPIRE_H=24
EMAIL_FROM=dojo@relodojo.app
EMAIL_FROM_NAME=Relo Dojo
# SMTP for relodojo.app (your provider). Yandex 360: smtp.yandex.ru:465 SMTP_SSL=true.
# Mail.ru for business: smtp.mail.ru:465 SMTP_SSL=true. For 587 use STARTTLS (SMTP_SSL=false).
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=dojo@relodojo.app
# SMTP_PASSWORD=
# SMTP_SSL=true
