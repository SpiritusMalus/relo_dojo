# relo_dojo PROD .env — FILLED TEMPLATE (text on Gemini + voice ON)
# 1) Copy to /opt/relo_dojo/backend/.env on the VPS
# 2) Fill every line marked  >>> FILL <<<  (4 values + optional SMTP)
# 3) chmod 600 .env
# NEVER commit the filled file — .env is gitignored.

# Hardened runtime: Swagger off, CHECK_SECRET required, HSTS emitted.
ENV=prod

# ============================================================================
# REQUIRED SECRETS (no defaults — the app refuses to start if any is missing)
# ============================================================================
# Generate ON THE BOX (don't paste secrets into chat — that compromises them):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=                       # >>> FILL <<<  (output of the command above)
# Generate ON THE BOX:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHECK_SECRET=                     # >>> FILL <<<  (output of the command above)
# Postgres on this VPS (localhost). Use the password you set for the `relo` DB user.
DATABASE_URL=postgresql+asyncpg://relo:>>>FILL_DB_PASSWORD<<<@127.0.0.1:5432/relo_dojo

# ============================================================================
# LLM PROVIDER — Gemini (text AND voice both use the Google key below)
# ============================================================================
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-3.1-flash-lite
# REAL Google AI Studio key — MUST start with  AIza...
# NOT an OpenRouter key (sk-or-...) — OpenRouter can't do Gemini voice at all.
# Get it here: https://aistudio.google.com/apikey
GEMINI_API_KEY=                   # >>> FILL <<<  (AIza...)
# Anthropic fallback — unused while LLM_PROVIDER=gemini. Leave empty.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ============================================================================
# VOICE (pronunciation read-aloud + realtime). Reuses GEMINI_API_KEY above.
# true => /voice/* is live. The realtime path also needs your Google project to
# have a native-audio Live model (verify_voice.py checks this).
# ============================================================================
VOICE_ENABLED=true

# --- Public URL (verification links, billing return) ---
APP_BASE_URL=https://relo.family-pie.ru
# Mobile app isn't a browser, so CORS can stay empty.
ALLOWED_ORIGINS=

# Behind Caddy (a proxy we control) → trust the first X-Forwarded-For hop.
TRUST_FORWARDED_FOR=true

# ============================================================================
# EMAIL (account activation). As-is, SMTP is OFF → activation links are only
# LOGGED, not sent. Fill these to actually email users (optional at launch).
# ============================================================================
EMAIL_FROM=dojo@relodojo.app
EMAIL_FROM_NAME="Relo Dojo"
# SMTP_HOST=                      # >>> FILL (optional): e.g. smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=dojo@relodojo.app
# SMTP_PASSWORD=                  # >>> FILL (optional)
# SMTP_SSL=true                   # true for port 465 (implicit TLS)

# --- Billing (premium) — OFF until enabled (separate task) ---
BILLING_ENABLED=false
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# BILLING_RETURN_URL=https://relo.family-pie.ru/checkout/done

# Schema auto-applies on startup (single instance). Keep true.
AUTO_MIGRATE=true
