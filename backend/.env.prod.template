# relo_dojo PROD .env — FILLED TEMPLATE (text + read-aloud voice, all via OpenRouter)
# 1) Copy to /opt/relo_dojo/backend/.env on the VPS
# 2) Fill every line marked  >>> FILL <<<  (OpenRouter key, 2 app secrets, DB pw, SMTP pw)
# 3) chmod 600 .env
# NEVER commit the filled file — .env is gitignored.
# NOTE: realtime voice (live dialog) is intentionally OUT — OpenRouter can't do it.

# Hardened runtime: Swagger off, CHECK_SECRET required, HSTS emitted.
ENV=prod

# ============================================================================
# REQUIRED SECRETS (no defaults — the app refuses to start if any is missing)
# ============================================================================
# Generate ON THE BOX (don't paste secrets into chat — that compromises them):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=                       # >>> FILL <<<  (output of the command above)
# Generate ON THE BOX:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHECK_SECRET=                     # >>> FILL <<<  (output of the command above)
# Postgres on this VPS (localhost). Use the password you set for the `relo` DB user.
DATABASE_URL=postgresql+asyncpg://relo:>>>FILL_DB_PASSWORD<<<@127.0.0.1:5432/relo_dojo

# ============================================================================
# LLM PROVIDER — OpenRouter (one sk-or key fronts text AND read-aloud voice)
# ============================================================================
LLM_PROVIDER=openrouter
# Your OpenRouter key — starts with  sk-or-v1-...   (https://openrouter.ai/keys)
OPENROUTER_API_KEY=               # >>> FILL <<<  (sk-or-v1-...)
# gemini-3.1-flash-lite (your pick) — confirmed on OpenRouter, and it accepts audio input,
# so the same slug does both text and read-aloud transcription.
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_TRANSCRIBE_MODEL=google/gemini-3.1-flash-lite
# Gemini-direct keys — NOT used on OpenRouter. Leave empty.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ============================================================================
# VOICE — read-aloud pronunciation only (realtime Live dialog is NOT available
# via OpenRouter). true => /voice/transcribe is live. verify_voice.py checks it.
# ============================================================================
VOICE_ENABLED=true

# --- Public URL (verification links, billing return) ---
APP_BASE_URL=https://relo.family-pie.ru
# Mobile app isn't a browser, so CORS can stay empty.
ALLOWED_ORIGINS=

# Behind Caddy (a proxy we control) → trust the first X-Forwarded-For hop.
TRUST_FORWARDED_FOR=true

# ============================================================================
# EMAIL (account activation) — reg.ru hosting mailbox relo@family-pie.ru.
# From MUST equal the authenticated mailbox, or reg.ru rejects/spam-flags it.
# If SMTP auth fails, try SMTP_HOST=sm33.hosting.reg.ru (your specific server).
# ============================================================================
EMAIL_FROM=relo@family-pie.ru
EMAIL_FROM_NAME="Relo Dojo"
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465
SMTP_USER=relo@family-pie.ru
SMTP_PASSWORD=                    # >>> FILL <<<  (пароль ящика relo@family-pie.ru из ISPmanager)
SMTP_SSL=true                     # true => implicit TLS on port 465

# --- Billing (premium) — OFF until enabled (separate task) ---
BILLING_ENABLED=false
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# BILLING_RETURN_URL=https://relo.family-pie.ru/checkout/done

# Schema auto-applies on startup (single instance). Keep true.
AUTO_MIGRATE=true
